# Server Environment Configuration Template

# Runtime environment (production, development, test)
NODE_ENV=production

# Port the backend server listens on
PORT=3000

# MongoDB connection string (Atlas or local instance)
MONGODB_URL=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/dbname

# JWT Auth Secret key (use a long random string for production)
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# JWT Expirations
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Email setup (using Brevo SMTP API Key)
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=info@yourdomain.com

# Groq API Key (for Whisper and Llama3 summaries)
GROQ_API_KEY=your_groq_api_key

# Cloudinary Integration (for profile photo uploads, optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend App URL (for password reset and email verification links)
FRONTEND_URL=http://localhost:5173
